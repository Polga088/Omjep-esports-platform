// ============================================================
// OMJEP — Schéma de base de données EA FC 26 E-Sport Platform
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  MANAGER
  PLAYER
}

enum Position {
  GK
  DC
  LAT
  RAT
  MDC
  MOC
  MG
  MD
  BU
  ATT
}

enum Platform {
  CROSSPLAY
  PS5
  XBOX
  PC
}

enum ClubRole {
  FOUNDER
  MANAGER
  CO_MANAGER
  PLAYER
}

enum MatchStatus {
  SCHEDULED
  LIVE
  PLAYED
  FINISHED
  CANCELLED
  DISPUTED
}

enum CompetitionType {
  LEAGUE
  CUP
}

enum CompetitionStatus {
  DRAFT
  ONGOING
  FINISHED
}

enum TransferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EventType {
  GOAL
  ASSIST
}

// ============================================================
// MODELS
// ============================================================

model User {
  id            String   @id @default(uuid()) @db.Uuid
  external_id   String?  @unique
  email         String   @unique
  password_hash String
  role          UserRole @default(PLAYER)
  created_at    DateTime @default(now())

  // Identifiants de jeu
  ea_persona_name String? @unique
  gamertag_psn    String?
  gamertag_xbox   String?

  // Profil sportif
  preferred_position Position?
  nationality        String?

  // Relations
  teamMemberships     TeamMember[]
  stats               PlayerStats?
  transferRequests    TransferRequest[]
  sentInvitations     Invitation[]      @relation("InvitationInviter")
  receivedInvitations Invitation[]      @relation("InvitationInvitee")
  matchEvents         MatchEvent[]

  @@map("users")
}

model Team {
  id           String   @id @default(uuid()) @db.Uuid
  proclubs_url String?  @unique
  name         String   @unique
  logo_url     String?
  created_at   DateTime @default(now())

  // Identifiants proclubs.io
  ea_club_id String?  @unique
  platform   Platform @default(CROSSPLAY)

  // Relations
  members          TeamMember[]
  homeMatches      Match[]           @relation("HomeTeam")
  awayMatches      Match[]           @relation("AwayTeam")
  competitions     CompetitionTeam[]
  transferRequests TransferRequest[]
  invitations      Invitation[]
  matchEvents      MatchEvent[]

  @@map("teams")
}

// Table de liaison Roster (Many-to-Many explicite User <-> Team)
model TeamMember {
  user_id   String   @db.Uuid
  team_id   String   @db.Uuid
  club_role ClubRole @default(PLAYER)
  joined_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@id([user_id, team_id])
  @@map("team_members")
}

// Statistiques individuelles globales (One-to-One avec User)
model PlayerStats {
  id      String @id @default(uuid()) @db.Uuid
  user_id String @unique @db.Uuid

  matches_played Int   @default(0)
  goals          Int   @default(0)
  assists        Int   @default(0)
  clean_sheets   Int   @default(0)
  motm           Int   @default(0) // Man of the Match count
  average_rating Float @default(0.0)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("player_stats")
}

// ============================================================
// COMPÉTITIONS
// ============================================================

model Competition {
  id         String            @id @default(uuid()) @db.Uuid
  name       String            @unique
  type       CompetitionType
  status     CompetitionStatus @default(DRAFT)
  start_date DateTime?
  end_date   DateTime?
  created_at DateTime          @default(now())

  teams   CompetitionTeam[]
  matches Match[]

  @@map("competitions")
}

// Table de liaison Many-to-Many Competition <-> Team
model CompetitionTeam {
  competition_id String   @db.Uuid
  team_id        String   @db.Uuid
  joined_at      DateTime @default(now())

  competition Competition @relation(fields: [competition_id], references: [id], onDelete: Cascade)
  team        Team        @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@id([competition_id, team_id])
  @@map("competition_teams")
}

model Match {
  id             String      @id @default(uuid()) @db.Uuid
  ea_match_id    String?     @unique
  competition_id String?     @db.Uuid
  round          String?
  home_team_id   String      @db.Uuid
  away_team_id   String      @db.Uuid
  home_score     Int?
  away_score     Int?
  status         MatchStatus @default(SCHEDULED)
  played_at      DateTime?

  competition Competition? @relation(fields: [competition_id], references: [id], onDelete: SetNull)
  homeTeam    Team         @relation("HomeTeam", fields: [home_team_id], references: [id])
  awayTeam    Team         @relation("AwayTeam", fields: [away_team_id], references: [id])
  events      MatchEvent[]

  @@map("matches")
}

model MatchEvent {
  id        String    @id @default(uuid()) @db.Uuid
  match_id  String    @db.Uuid
  player_id String    @db.Uuid
  team_id   String    @db.Uuid
  type      EventType
  minute    Int?

  match  Match @relation(fields: [match_id], references: [id], onDelete: Cascade)
  player User  @relation(fields: [player_id], references: [id], onDelete: Cascade)
  team   Team  @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@map("match_events")
}

// Mercato — demandes de transfert
model TransferRequest {
  id         String         @id @default(uuid()) @db.Uuid
  player_id  String         @db.Uuid
  team_id    String         @db.Uuid
  status     TransferStatus @default(PENDING)
  created_at DateTime       @default(now())

  player User @relation(fields: [player_id], references: [id], onDelete: Cascade)
  team   Team @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@map("transfer_requests")
}

// Mercato — invitations envoyées par un manager à un joueur
model Invitation {
  id            String           @id @default(uuid()) @db.Uuid
  team_id       String           @db.Uuid
  inviter_id    String           @db.Uuid
  invitee_email String
  invitee_id    String?          @db.Uuid
  status        InvitationStatus @default(PENDING)
  created_at    DateTime         @default(now())

  team    Team  @relation(fields: [team_id], references: [id], onDelete: Cascade)
  inviter User  @relation("InvitationInviter", fields: [inviter_id], references: [id], onDelete: Cascade)
  invitee User? @relation("InvitationInvitee", fields: [invitee_id], references: [id], onDelete: SetNull)

  @@map("invitations")
}
