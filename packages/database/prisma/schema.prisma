generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String             @id @default(uuid()) @db.Uuid
  email               String             @unique
  password_hash       String
  role                UserRole           @default(PLAYER)
  created_at          DateTime           @default(now())
  ea_persona_name     String?            @unique
  gamertag_psn        String?
  gamertag_xbox       String?
  preferred_position  Position?
  nationality         String?
  external_id         String?            @unique
  level               Int                @default(1)
  xp                  Int                @default(0)
  omjepCoins          Int                @default(1000) @map("omjep_coins")
  jepyCoins           Int                @default(0) @map("jepy_coins")
  isPremium           Boolean            @default(false) @map("is_premium")
  contracts           Contract[]
  receivedInvitations Invitation[]       @relation("InvitationInvitee")
  sentInvitations     Invitation[]       @relation("InvitationInviter")
  matchEvents         MatchEvent[]
  matchScoreReports   MatchScoreReport[]
  notifications       Notification[]
  stats               PlayerStats?
  teamMemberships     TeamMember[]
  managedClubs        Club[]             @relation("ClubManager")
  transferOffers      TransferOffer[]    @relation("TransferOfferPlayer")
  transferRequests    TransferRequest[]
  inventory           UserInventory[]
  predictions         Prediction[]
  subscriptions       UserSubscription[]

  @@map("users")
}

/// Club Pro Clubs (table SQL `teams`).
model Club {
  id                String             @id @default(uuid()) @db.Uuid
  name              String             @unique
  logo_url          String?
  created_at        DateTime           @default(now())
  ea_club_id        String?            @unique
  platform          Platform           @default(CROSSPLAY)
  proclubs_url      String?            @unique
  budget            Float              @default(1000000)
  prestige_level    Int                @default(1)
  xp                Int                @default(0)
  description       String?
  manager_id        String?            @db.Uuid
  validation_status ValidationStatus   @default(PENDING)
  presidentPremium  Boolean            @default(false) @map("president_premium")
  competitions      CompetitionTeam[]
  contracts         Contract[]
  invitations       Invitation[]
  matchEvents       MatchEvent[]
  matchScoreReports MatchScoreReport[]
  awayMatches       Match[]            @relation("AwayTeam")
  homeMatches       Match[]            @relation("HomeTeam")
  members           TeamMember[]
  manager           User?              @relation("ClubManager", fields: [manager_id], references: [id])
  transactions      Transaction[]
  sentOffers        TransferOffer[]    @relation("OfferFromTeam")
  receivedOffers    TransferOffer[]    @relation("OfferToTeam")
  transferRequests  TransferRequest[]

  @@map("teams")
}

model TeamMember {
  user_id   String   @db.Uuid
  team_id   String   @db.Uuid
  club_role ClubRole @default(PLAYER)
  joined_at DateTime @default(now())
  team      Club     @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, team_id])
  @@map("team_members")
}

model PlayerStats {
  id             String @id @default(uuid()) @db.Uuid
  user_id        String @unique @db.Uuid
  matches_played Int    @default(0)
  goals          Int    @default(0)
  assists        Int    @default(0)
  clean_sheets   Int    @default(0)
  motm           Int    @default(0)
  average_rating Float  @default(0.0)
  user           User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("player_stats")
}

model Competition {
  id         String            @id @default(uuid()) @db.Uuid
  name       String            @unique
  type       CompetitionType
  status     CompetitionStatus @default(DRAFT)
  start_date DateTime?
  end_date   DateTime?
  created_at DateTime          @default(now())
  teams      CompetitionTeam[]
  matches    Match[]

  @@map("competitions")
}

model CompetitionTeam {
  competition_id String      @db.Uuid
  team_id        String      @db.Uuid
  joined_at      DateTime    @default(now())
  competition    Competition @relation(fields: [competition_id], references: [id], onDelete: Cascade)
  team           Club        @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@id([competition_id, team_id])
  @@map("competition_teams")
}

model Match {
  id             String             @id @default(uuid()) @db.Uuid
  ea_match_id    String?            @unique
  home_team_id   String             @db.Uuid
  away_team_id   String             @db.Uuid
  home_score     Int?
  away_score     Int?
  status         MatchStatus        @default(SCHEDULED)
  played_at      DateTime?
  competition_id String?            @db.Uuid
  round          String?
  events         MatchEvent[]
  scoreReports   MatchScoreReport[]
  awayTeam       Club               @relation("AwayTeam", fields: [away_team_id], references: [id])
  competition    Competition?       @relation(fields: [competition_id], references: [id])
  homeTeam       Club               @relation("HomeTeam", fields: [home_team_id], references: [id])
  predictions    Prediction[]

  @@map("matches")
}

model MatchScoreReport {
  id                String   @id @default(uuid()) @db.Uuid
  match_id          String   @db.Uuid
  reporting_team_id String   @db.Uuid
  submitted_by_id   String   @db.Uuid
  home_score        Int
  away_score        Int
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  match             Match    @relation(fields: [match_id], references: [id], onDelete: Cascade)
  reportingTeam     Club     @relation(fields: [reporting_team_id], references: [id], onDelete: Cascade)
  submittedBy       User     @relation(fields: [submitted_by_id], references: [id], onDelete: Cascade)

  @@unique([match_id, reporting_team_id])
  @@map("match_score_reports")
}

model MatchEvent {
  id        String    @id @default(uuid()) @db.Uuid
  match_id  String    @db.Uuid
  player_id String    @db.Uuid
  team_id   String    @db.Uuid
  type      EventType
  minute    Int?
  match     Match     @relation(fields: [match_id], references: [id], onDelete: Cascade)
  player    User      @relation(fields: [player_id], references: [id], onDelete: Cascade)
  team      Club      @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@map("match_events")
}

model TransferRequest {
  id         String         @id @default(uuid()) @db.Uuid
  player_id  String         @db.Uuid
  team_id    String         @db.Uuid
  status     TransferStatus @default(PENDING)
  created_at DateTime       @default(now())
  player     User           @relation(fields: [player_id], references: [id], onDelete: Cascade)
  team       Club           @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@map("transfer_requests")
}

model Invitation {
  id            String           @id @default(uuid()) @db.Uuid
  team_id       String           @db.Uuid
  inviter_id    String           @db.Uuid
  invitee_email String
  invitee_id    String?          @db.Uuid
  status        InvitationStatus @default(PENDING)
  created_at    DateTime         @default(now())
  invitee       User?            @relation("InvitationInvitee", fields: [invitee_id], references: [id])
  inviter       User             @relation("InvitationInviter", fields: [inviter_id], references: [id], onDelete: Cascade)
  team          Club             @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Contract {
  id             String   @id @default(uuid()) @db.Uuid
  team_id        String   @db.Uuid
  user_id        String   @db.Uuid
  salary         Float
  release_clause Float
  expires_at     DateTime
  team           Club     @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("contracts")
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  team_id     String          @db.Uuid
  amount      Float
  type        TransactionType
  description String?
  created_at  DateTime        @default(now())
  team        Club            @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model TransferOffer {
  id           String         @id @default(uuid()) @db.Uuid
  player_id    String         @db.Uuid
  from_team_id String         @db.Uuid
  to_team_id   String         @db.Uuid
  amount       Float
  status       TransferStatus @default(PENDING)
  created_at   DateTime       @default(now())
  responded_at DateTime?
  fromTeam     Club           @relation("OfferFromTeam", fields: [from_team_id], references: [id], onDelete: Cascade)
  player       User           @relation("TransferOfferPlayer", fields: [player_id], references: [id], onDelete: Cascade)
  toTeam       Club           @relation("OfferToTeam", fields: [to_team_id], references: [id], onDelete: Cascade)

  @@map("transfer_offers")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  title      String
  message    String
  is_read    Boolean  @default(false)
  metadata   Json?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model StoreItem {
  id          String            @id @default(uuid()) @db.Uuid
  name        String
  description String            @db.Text
  priceJepy   Int               @map("price_jepy")
  category    StoreItemCategory
  imageUrl    String            @map("image_url")
  isAvailable Boolean           @default(true) @map("is_available")

  inventory UserInventory[]

  @@map("store_items")
}

model UserInventory {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      String    @db.Uuid
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  item_id      String    @db.Uuid
  item         StoreItem @relation(fields: [item_id], references: [id], onDelete: Cascade)
  purchased_at DateTime  @default(now()) @map("purchased_at")

  @@unique([user_id, item_id])
  @@map("user_inventory")
}

model Prediction {
  id         String           @id @default(uuid()) @db.Uuid
  user_id    String           @db.Uuid
  user       User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  match_id   String           @db.Uuid
  match      Match            @relation(fields: [match_id], references: [id], onDelete: Cascade)
  homeScore  Int              @map("home_score")
  awayScore  Int              @map("away_score")
  betAmount  Int              @map("bet_amount")
  status     PredictionStatus @default(PENDING)
  created_at DateTime         @default(now()) @map("created_at")

  @@unique([user_id, match_id])
  @@map("predictions")
}

enum UserRole {
  ADMIN
  MANAGER
  PLAYER
  MODERATOR
}

enum Position {
  GK
  DC
  LAT
  RAT
  MDC
  MOC
  MG
  MD
  BU
  ATT
}

enum Platform {
  CROSSPLAY
  PS5
  XBOX
  PC
}

enum ClubRole {
  FOUNDER
  MANAGER
  CO_MANAGER
  PLAYER
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  DISPUTED
  PLAYED
  CANCELLED
}

enum CompetitionType {
  LEAGUE
  CUP
}

enum CompetitionStatus {
  DRAFT
  ONGOING
  FINISHED
}

enum TransferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventType {
  GOAL
  ASSIST
}

enum TransactionType {
  MATCH_REWARD
  TRANSFER
  WAGE
}

enum StoreItemCategory {
  BANNER
  AVATAR_FRAME
  BADGE
}

enum PredictionStatus {
  PENDING
  WON
  LOST
}

enum SubscriptionPlanCode {
  PLAYER
  PRESIDENT
}

enum UserSubscriptionStatus {
  ACTIVE
  EXPIRED
}

model SubscriptionPlan {
  id           String               @id @default(uuid()) @db.Uuid
  code         SubscriptionPlanCode @unique
  name         String
  priceJepy    Int                  @map("price_jepy")
  durationDays Int                  @default(30) @map("duration_days")
  features     Json
  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id         String                 @id @default(uuid()) @db.Uuid
  user_id    String                 @db.Uuid
  user       User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan_id    String                 @db.Uuid
  plan       SubscriptionPlan       @relation(fields: [plan_id], references: [id], onDelete: Restrict)
  start_date DateTime               @map("start_date")
  end_date   DateTime               @map("end_date")
  status     UserSubscriptionStatus @default(ACTIVE)

  @@index([user_id, status])
  @@index([end_date, status])
  @@map("user_subscriptions")
}
